# LLM Configuration
LLM_PROVIDER=openai  # openai, anthropic, local
LLM_MODEL=gpt-4
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Speech-to-Text Configuration
STT_PROVIDER=openai  # openai, azure, google
OPENAI_API_KEY=your_openai_key_here

# Text-to-Speech Configuration
TTS_PROVIDER=elevenlabs  # elevenlabs, aws, google, azure
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=your_voice_id

# AWS Configuration (if using AWS services)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1

# Azure Configuration (if using Azure services)
AZURE_SPEECH_KEY=your_speech_key
AZURE_SPEECH_REGION=your_region

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost/ai_voice_agent
REDIS_URL=redis://localhost:6379

# Environment
ENVIRONMENT=development  # development, staging, production
DEBUG=true
LOG_LEVEL=info

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Security
SECRET_KEY=your-secret-key-change-this
JWT_SECRET=your-jwt-secret-key

# Monitoring
SENTRY_DSN=your_sentry_dsn
ENABLE_METRICS=true

# Voice Configuration
MAX_CONCURRENT_CALLS=100
CALL_TIMEOUT_SECONDS=3600
VOICE_SAMPLE_RATE=16000
VOICE_CHANNELS=1